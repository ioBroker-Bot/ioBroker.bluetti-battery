{
	"i18n": true,
	"type": "panel",
	"items": {
		"macAddress": {
			"type": "text",
			"label": "MAC address",
			"help": "Bluetooth MAC address of the device, e.g. AA:BB:CC:DD:EE:FF",
			"newLine": true,
			"xs": 12,
			"sm": 12,
			"md": 6,
			"lg": 4,
			"xl": 4
		},
		"deviceType": {
			"type": "select",
			"label": "Device type",
			"help": "Leave on auto to detect from the advertised Bluetooth name",
			"newLine": true,
			"options": [
				{ "label": "Auto detect", "value": "auto" },
				{ "label": "AC200M", "value": "AC200M" },
				{ "label": "AC200L", "value": "AC200L" },
				{ "label": "AC300", "value": "AC300" },
				{ "label": "AC500", "value": "AC500" },
				{ "label": "AC240", "value": "AC240" },
				{ "label": "AC180 (experimental)", "value": "AC180" },
				{ "label": "AC2A (experimental)", "value": "AC2A" },
				{ "label": "AC60", "value": "AC60" },
				{ "label": "AC70 (experimental)", "value": "AC70" },
				{ "label": "EP500", "value": "EP500" },
				{ "label": "EP500P", "value": "EP500P" },
				{ "label": "EP600", "value": "EP600" },
				{ "label": "EB3A", "value": "EB3A" },
				{ "label": "V2 / encrypted (experimental)", "value": "V2" }
			],
			"default": "auto",
			"xs": 12,
			"sm": 12,
			"md": 6,
			"lg": 4,
			"xl": 4
		},
		"pollInterval": {
			"type": "number",
			"label": "Polling interval (s)",
			"min": 2,
			"max": 3600,
			"default": 10,
			"newLine": true,
			"xs": 12,
			"sm": 6,
			"md": 4,
			"lg": 3,
			"xl": 3
		},
		"pollPacks": {
			"type": "checkbox",
			"label": "Poll per-pack battery data",
			"help": "Reads cell voltages and per-pack details (slower)",
			"default": false,
			"newLine": true,
			"xs": 12,
			"sm": 12,
			"md": 6,
			"lg": 4,
			"xl": 4
		},
		"encryption": {
			"type": "select",
			"label": "Encryption (v2 devices)",
			"help": "auto follows the device profile; force on/off for newer encrypted units",
			"newLine": true,
			"options": [
				{ "label": "Auto", "value": "auto" },
				{ "label": "On", "value": "on" },
				{ "label": "Off", "value": "off" }
			],
			"default": "auto",
			"xs": 12,
			"sm": 12,
			"md": 6,
			"lg": 4,
			"xl": 4
		}
	}
}
